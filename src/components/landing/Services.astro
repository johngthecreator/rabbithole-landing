---
import BgGrid from "@/components/assets/BgGrid.astro";

const features = [
  {
    title: "Turn Reading Into Watching",
    description:
      "Any article, paper, or webpage becomes an auto-generated video with captions and immersive footage. Your brain stays locked in. The knowledge actually sticks.",
  },
  {
    title: "Instant Summaries",
    description:
      "Get a clean, accurate summary of anything you're reading in seconds. Stop skimming. Start knowing.",
  },
  {
    title: "Private by Default",
    description:
      "No internet required. No data collected. No API keys. RabbitHole runs entirely on your device so your reading stays yours — always.",
  },
];
---

<section class="border-white/20 border-b divide-y divide-white/20">
  <div class="px-8 py-6 relative">
    <BgGrid />
    <h2 class="text-3xl font-black text-white uppercase">
      Features
    </h2>
  </div>
  <div
    class="text-white text-xs gap-3 gap-y-12 grid grid-cols-1 md:grid-cols-3 "
  >
    {
      features.map(({ title, description }) => (
        <div class="p-8">
          <h3 class="text-lg uppercase font-black text-white">{title}</h3>
          <p class="mt-3 text-eagle text-sm">{description}</p>
        </div>
      ))
    }
  </div>
</section>
