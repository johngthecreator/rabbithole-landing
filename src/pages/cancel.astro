---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BgGrid from "@/components/assets/BgGrid.astro";
---

<BaseLayout>
  <section class="border-b border-white/20">
    <div class="relative p-8 h-[calc(100vh-var(--nav-height,64px))] flex items-center justify-center">
      <BgGrid />
      <div class="relative z-10 text-center max-w-lg">
        <h1 class="text-white font-black uppercase tracking-tighter text-4xl lg:text-6xl">
          Something Went Wrong
        </h1>
        <p class="text-white/60 mt-4 text-lg">
          Your payment could not be completed. Please reach out to support directly from the RabbitHole extension page and we'll get it sorted.
        </p>
        <a
          href="https://chromewebstore.google.com/detail/rabbithole/dldneoaipflgcldijkcjkfknemcjbcbh"
          class="mt-8 inline-flex items-center justify-center px-8 py-4 bg-white text-black font-black uppercase text-sm rounded-full hover:bg-orange hover:text-white transition duration-200"
        >
          Go to Extension Page
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
